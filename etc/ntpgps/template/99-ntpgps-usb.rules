# FTDI USB-to-Serial converter, connected to GPS module with PPS
#[RULE1_START]
#SUBSYSTEM=="tty", KERNEL=="ttyUSB[0-9]*", ATTRS{idVendor}=="0403", ATTRS{idProduct}=="6001", \
#    PROGRAM="/usr/local/bin/ntpgps-gpsnum.sh %k", SYMLINK+="gps%c", TAG+="systemd", \
#    ENV{SYSTEMD_WANTS}="ntpgps-gps-pps@%k.service", \
#    MODE="0666"
#[RULE1_END]

# FTDI USB-to-Serial converter, connected to GPS module
#[RULE2_START]
#SUBSYSTEM=="tty", KERNEL=="ttyUSB[0-9]*", ATTRS{idVendor}=="0403", ATTRS{idProduct}=="6001", \
#    PROGRAM="/usr/local/bin/ntpgps-gpsnum.sh %k", SYMLINK+="gps%c", TAG+="systemd", \
#    ENV{SYSTEMD_WANTS}="ntpgps-gps-nopps@%k.service", \
#    MODE="0666"
#[RULE2_END]

# FTDI USB-to-Serial converter with S/N, connected to GPS module with PPS
#[RULE3_START]
#SUBSYSTEM=="tty", KERNEL=="ttyUSB[0-9]*", ATTRS{idVendor}=="0403", ATTRS{idProduct}=="6001", \
#    ATTRS{serial}=="00000000", \
#    PROGRAM="/usr/local/bin/ntpgps-gpsnum.sh %k", SYMLINK+="gps%c", TAG+="systemd", \
#    ENV{SYSTEMD_WANTS}="ntpgps-gps-pps@%k.service", \
#    MODE="0666"
#[RULE3_END]

# FTDI USB-to-Serial converter with S/N, connected to GPS module
#[RULE4_START]
#SUBSYSTEM=="tty", KERNEL=="ttyUSB[0-9]*", ATTRS{idVendor}=="0403", ATTRS{idProduct}=="6001", \
#    ATTRS{serial}=="00000000", \
#    PROGRAM="/usr/local/bin/ntpgps-gpsnum.sh %k", SYMLINK+="gps%c", TAG+="systemd", \
#    ENV{SYSTEMD_WANTS}="ntpgps-gps-nopps@%k.service", \
#    MODE="0666"
#[RULE4_END]

# CH340 USB-to-Serial converter, connected to GPS module with PPS
#[RULE5_START]
#SUBSYSTEM=="tty", KERNEL=="ttyUSB[0-9]*", ATTRS{idVendor}=="1a86", ATTRS{idProduct}=="7523", \
#    PROGRAM="/usr/local/bin/ntpgps-gpsnum.sh %k", SYMLINK+="gps%c", TAG+="systemd", \
#    ENV{SYSTEMD_WANTS}="ntpgps-gps-pps@%k.service", \
#    MODE="0666"
#[RULE5_END]

# CH340 USB-to-Serial converter, connected to GPS module
#[RULE6_START]
#SUBSYSTEM=="tty", KERNEL=="ttyUSB[0-9]*", ATTRS{idVendor}=="1a86", ATTRS{idProduct}=="7523", \
#    PROGRAM="/usr/local/bin/ntpgps-gpsnum.sh %k", SYMLINK+="gps%c", TAG+="systemd", \
#    ENV{SYSTEMD_WANTS}="ntpgps-gps-nopps@%k.service", \
#    MODE="0666"
#[RULE6_END]

# VK172 USB GPS dongle
#[RULE7_START]
#SUBSYSTEM=="tty", KERNEL=="ttyACM[0-9]*", ATTRS{idVendor}=="1546", ATTRS{idProduct}=="01a7", \
#    ATTRS{manufacturer}=="u-blox AG - www.u-blox.com", ATTRS{product}=="u-blox 7 - GPS/GNSS Receiver", \
#    PROGRAM="/usr/local/bin/ntpgps-gpsnum.sh %k", SYMLINK+="gps%c", TAG+="systemd", \
#    ENV{SYSTEMD_WANTS}="ntpgps-gps-ublox7-config@%k.service", \
#    MODE="0666"
#[RULE7_END]


################################################################################
# Handles creation and removal of /dev/gpsppsN for NTP
#
ACTION=="add", SUBSYSTEM=="pps", \
    PROGRAM="/usr/local/bin/ntpgps-gpspps-symlink.sh %k", \
    SYMLINK+="%c"

